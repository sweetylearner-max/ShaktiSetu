<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Soft Outer Ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/sos_outer"/>
        </shape>
    </item>

    <!-- Inner Circle -->
    <item
        android:left="4dp"
        android:right="4dp"
        android:top="4dp"
        android:bottom="4dp">

        <shape android:shape="oval">
            <solid android:color="@color/nav_active"/>
        </shape>
    </item>

</layer-list>