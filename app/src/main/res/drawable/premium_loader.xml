<?xml version="1.0" encoding="utf-8"?>
<rotate xmlns:android="http://schemas.android.com/apk/res/android"
    android:fromDegrees="0"
    android:pivotX="50%"
    android:pivotY="50%"
    android:toDegrees="1080">
    <shape
        android:innerRadiusRatio="3"
        android:shape="ring"
        android:thicknessRatio="15"
        android:useLevel="false">
        <gradient
            android:centerColor="@color/cinematic_rose_accent"
            android:centerY="0.5"
            android:endColor="@color/cinematic_bg_light"
            android:startColor="@color/cinematic_rose_accent"
            android:type="sweep" />
    </shape>
</rotate>