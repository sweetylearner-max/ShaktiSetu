<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer Glow Ring -->
    <item>
        <shape android:shape="oval">

            <solid android:color="@color/sos_outer"/>

            <size
                android:width="240dp"
                android:height="240dp"/>

        </shape>
    </item>

    <!-- Main SOS Circle -->
    <item
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp">

        <shape android:shape="oval">

            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#B6455B"
                android:centerColor="#C8566D"
                android:endColor="#D15F76"/>

        </shape>

    </item>

</layer-list>