<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/navIncludeRoot"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp">

            <!-- Back button (hidden) -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fake Call"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <!-- Caller Card -->
            <LinearLayout
                android:id="@+id/callerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <!-- Avatar -->
                <TextView
                    android:id="@+id/tvCallerAvatar"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/avatar_circle"
                    android:gravity="center"
                    android:text="H"
                    android:textColor="@color/text_white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <!-- Name Section -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Called as"
                        android:textColor="@color/text_hint"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvCallerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Harsh"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Edit Button -->
                <LinearLayout
                    android:id="@+id/btnEditCaller"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✏️ Edit"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Timer Buttons -->
            <LinearLayout
                android:id="@+id/timerRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/btn5s"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/timer_btn_selected"
                    android:gravity="center"
                    android:text="5s"
                    android:textColor="@color/text_white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn10s"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/timer_btn_unselected"
                    android:gravity="center"
                    android:text="10s"
                    android:textColor="#3B7DFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn30s"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/timer_btn_unselected"
                    android:gravity="center"
                    android:text="30s"
                    android:textColor="#3B7DFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn60s"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/timer_btn_unselected"
                    android:gravity="center"
                    android:text="60s"
                    android:textColor="#3B7DFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Ringtone Row -->
            <LinearLayout
                android:id="@+id/ringtoneRow"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/ringtone_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎵"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvRingtoneName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Ringtone"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/text_hint"
                    android:textSize="24sp" />
            </LinearLayout>

            <!-- Schedule Call Button -->
            <Button
                android:id="@+id/btnScheduleCall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:backgroundTint="@null"
                android:background="@drawable/black_button"
                android:text="Schedule Call"
                android:textAllCaps="false"
                android:textColor="@color/background"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

    <!-- Nav Bar -->
    <include
        android:id="@+id/navIncludeRoot"
        layout="@layout/nav_bar_include" />

</RelativeLayout>